{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neowlogs.local/schema/neowlogs-event.schema.json",
  "title": "NeowLogs Event",
  "type": "object",
  "required": ["schema_version", "run_id", "timestamp_ms", "event_type"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "run_id": { "type": "string" },
    "combat_id": { "type": ["string", "null"] },
    "timestamp_ms": { "type": "integer" },
    "act": { "type": ["integer", "null"] },
    "floor": { "type": ["integer", "null"] },
    "turn": { "type": ["integer", "null"] },
    "actor_player_id": { "type": ["string", "null"] },
    "actor_name": { "type": ["string", "null"] },
    "target_id": { "type": ["string", "null"] },
    "target_name": { "type": ["string", "null"] },
    "event_type": {
      "type": "string",
      "enum": [
        "run_started",
        "run_ended",
        "combat_started",
        "combat_ended",
        "turn_started",
        "turn_ended",
        "card_played",
        "damage_dealt",
        "damage_observed",
        "damage_taken",
        "block_gained",
        "block_broken",
        "healing_done",
        "hp_lost",
        "buff_applied",
        "debuff_applied",
        "power_applied",
        "enemy_killed",
        "potion_used",
        "relic_triggered",
        "card_drawn",
        "energy_gained",
        "card_added",
        "card_removed",
        "card_upgraded",
        "gold_gained",
        "gold_spent",
        "floor_entered"
      ]
    },
    "amount": { "type": ["number", "null"] },
    "base_amount": { "type": ["number", "null"] },
    "source_type": { "type": ["string", "null"] },
    "source_name": { "type": ["string", "null"] },
    "metadata": { "type": "object" }
  },
  "additionalProperties": true
}
